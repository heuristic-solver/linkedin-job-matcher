# ============================================================
# REQUIRED: Google Gemini API Key
# Get yours free at: https://aistudio.google.com/apikey
# This is the PRIMARY extractor — paste your key below.
# ============================================================
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# Flask secret key (change this to any random string in production)
FLASK_SECRET_KEY=linkedin-job-matcher-secret-key-2026

# Optional settings
USE_EXTERNAL_FEEDS=false

# Ollama Global/Hosted API Configuration
# If hosting Ollama on a server, set the public/internal URL here.
# Default for local Docker is http://ollama:11434/api/generate
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma3:12b
# If your hosted Ollama requires an API key (Bearer token)
OLLAMA_API_KEY=
